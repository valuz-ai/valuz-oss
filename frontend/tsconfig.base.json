{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@valuz/shared": ["./packages/shared/src/index.ts"],
      "@valuz/core": ["./packages/core/src/index.ts"],
      "@valuz/core/types": ["./packages/core/src/types.ts"],
      "@valuz/core/config/features": ["./packages/core/src/config/features.ts"],
      "@valuz/parser-plugins": ["./packages/parser-plugins/src/index.ts"],
      "@valuz/ui": ["./packages/ui/src/index.ts"],
      "@valuz/app": ["./packages/app/src/index.ts"],
      "@valuz/app/platform": ["./packages/app/src/platform/index.ts"],
      "@valuz/app/pages": ["./packages/app/src/pages/index.ts"],
      "@valuz/app/components": ["./packages/app/src/components/index.ts"],
      "@valuz/app/hooks": ["./packages/app/src/hooks/index.ts"],
      "@valuz/app/layout": ["./packages/app/src/layout/index.ts"],
      "@valuz/app/routes": ["./packages/app/src/routes/index.ts"],
      "@valuz/app/lib/*": ["./packages/app/src/lib/*"],
      "@valuz/ui/tailwind-preset": ["./packages/ui/tailwind.preset.ts"],
      "@valuz/ui/styles/workspace.css": ["./packages/ui/src/styles/workspace.css"],
      "@valuz/ui/components/ui/*": ["./packages/ui/src/components/ui/*"],
      "@valuz/ui/hooks/*": ["./packages/ui/src/hooks/*"],
      "@valuz/ui/lib/*": ["./packages/ui/src/lib/*"]
    }
  }
}
